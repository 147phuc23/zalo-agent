APP_PORT=3011
REDIS_URL=redis://127.0.0.1:6379

# This repo's Supabase instance (ports from supabase/config.toml)
SUPABASE_URL=http://127.0.0.1:64321

# Use the local service_role JWT. Generate from the local JWT secret.
# Default local secret used by Supabase is:
# super-secret-jwt-token-with-at-least-32-characters-long
# You can generate a service_role token with the one-liner in README or ask me to regenerate.
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Connector -> API auth (any long random string)
INTERNAL_INGEST_TOKEN=replace_me

# Zalo connector -> API
# Shared API base URL for the admin proxy and connector
API_BASE_URL=http://localhost:3010
TENANT_ID=11111111-1111-1111-1111-111111111111

# OpenRouter (agent runtime)
OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Twenty CRM (Docker: http://localhost:4000 per docker-compose.yml)
TWENTY_BASE_URL=http://localhost:3000
TWENTY_API_KEY=replace_me

# HR agent skill registry: `mock` (default, local mocked CRM tools) or `twenty` (Twenty-backed tools).
# HR_SKILL_MODE=twenty
# Set to 1 to log OpenRouter URL, masked key, and model (packages/ai-client + hr CLI).
# Or pass --debug-steps to agent:hr:chat / agent:hr:demo (also sets this for the run).
# DEBUG_OPENROUTER=1
