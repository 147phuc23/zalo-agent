{
  "name": "zalo-twenty-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-down.sh",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "zalo:listen": "node services/zalo-connector/src/index.js",
    "api:dev": "pnpm --filter @platform/api dev",
    "worker:dev": "pnpm --filter @platform/worker dev",
    "twenty:up": "docker compose up -d",
    "twenty:down": "docker compose down",
    "recruiting:schema": "pnpm --filter @platform/worker twenty:schema",
    "recruiting:seed": "pnpm --filter @platform/worker twenty:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.18",
    "eslint": "^9.28.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.59.2",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
