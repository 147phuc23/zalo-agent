{
  "name": "zalo-twenty-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-down.sh",
    "dev:setup": "echo 'Database migrations run automatically on API start. To reset database, run docker compose down -v'",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "zalo:listen": "node services/zalo-connector/src/index.js",
    "api:dev": "pnpm --filter @platform/api dev",
    "worker:dev": "pnpm --filter @platform/worker dev",
    "twenty:up": "docker compose up -d",
    "twenty:down": "docker compose down",
    "recruiting:schema": "pnpm --filter @platform/worker twenty:schema",
    "recruiting:seed": "pnpm --filter @platform/worker twenty:seed",
    "db:migrate": "pnpm --filter @platform/database migrate",
    "db:seed:sql-jobs": "pnpm --filter @platform/database seed:sql-jobs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.21",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.6"
  }
}
