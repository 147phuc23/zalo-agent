{
  "name": "@platform/database",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./repositories": "./src/repositories.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "migrate": "tsx src/migrate-cli.ts",
    "seed:jobs": "tsx src/seed-jobs.ts",
    "seed:sql-jobs": "tsx src/seed-jobs-from-sql.ts"
  },
  "dependencies": {
    "@platform/config": "workspace:*",
    "@platform/shared": "workspace:*",
    "pg": "^8.13.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
